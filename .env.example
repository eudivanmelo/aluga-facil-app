# Base URL of the aluga-facil-api backend (must be reachable from the device/emulator running the app).
# Port is 8080 when running the API via docker-compose (aluga-facil-api), 5000 for a bare `dotnet run`.
# - Web / iOS simulator: http://localhost:8080/api
# - Android emulator:    http://10.0.2.2:8080/api
# - Physical device:     http://<your-machine-LAN-IP>:8080/api
EXPO_PUBLIC_API_URL=http://localhost:8080/api
